// Expression Conversion: Infix to Prefix
#include<stdio.h>
#include<ctype.h>
#include<string.h>
#include<stdlib.h>

int precedence(char opr){
    switch (opr){
        case '+':
        case '-':
            return 1;
        case '*':
        case '/':
            return 2;
        case '^':
            return 3;
        default:
            return 0;
    }
}

void reverse(char* exp){
    int len = strlen(exp);
    for(int i = 0; i < len/2; i++){
        char temp = exp[i];
        exp[i] = exp[len-i-1];
        exp[len-i-1] = temp;
    }
}

char* convertInfixToPrefix(char* infixExp){
    int len = strlen(infixExp);
    int top = -1, x = 0;

    char* prefix = (char*) malloc(len + 1);
    char operator[len];

    // Step 1: Reverse infix
    reverse(infixExp);

    // Step 2: Swap brackets
    for(int i = 0; i < len; i++){
        if(infixExp[i] == '(')
            infixExp[i] = ')';
        else if(infixExp[i] == ')')
            infixExp[i] = '(';
    }

    // Step 3: Same logic as postfix conversion
    for(int i = 0; i < len; i++){
        char ch = infixExp[i];

        if(isalnum(ch)){
            prefix[x++] = ch;
        }
        else if(ch == '+' || ch == '-' || ch == '*' || ch == '/' || ch == '^'){
            while(top != -1 && precedence(ch) < precedence(operator[top])){
                prefix[x++] = operator[top--];
            }
            operator[++top] = ch;
        }
        else if(ch == '('){
            operator[++top] = ch;
        }
        else if(ch == ')'){
            while(operator[top] != '('){
                prefix[x++] = operator[top--];
            }
            top--;
        }
    }

    while(top != -1){
        prefix[x++] = operator[top--];
    }

    prefix[x] = '\0';

    // Step 4: Reverse result to get Prefix
    reverse(prefix);

    return prefix;
}

int main(){
    char expr[100];

    printf("Enter Infix Expression: ");
    fgets(expr, sizeof(expr), stdin);
    expr[strcspn(expr, "\n")] = '\0';

    char* result = convertInfixToPrefix(expr);
    printf("Prefix expression = %s\n", result);

    free(result);
    return 0;
}
